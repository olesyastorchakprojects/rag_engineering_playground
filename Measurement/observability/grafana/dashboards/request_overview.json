{
  "title": "Runtime Reliability & Latency",
  "uid": "rag-request-overview",
  "schemaVersion": 41,
  "version": 18,
  "refresh": "30s",
  "panels": [
    {
      "title": "Request Duration p50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(rag_request_duration_ms_bucket[120s])))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ]
    },
