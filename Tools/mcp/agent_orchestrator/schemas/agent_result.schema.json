{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_orchestrator/agent_result.schema.json",
  "title": "AgentResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "step_id",
    "agent",
    "status",
    "summary",
    "recommended_next_agent"
  ],
  "properties": {
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "agent": {
      "type": "string",
      "enum": [
        "Coordinator",
        "Code Writer Agent",
        "Test Writer Agent",
        "Spec Conformance Agent",
        "Code Review Agent",
        "Coverage & Gaps Agent"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "tests_changed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "spec_inputs_used": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "mcps_consulted": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "commands_run": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "code_updates_needed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "spec_updates_needed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "mcp_updates_needed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "recommended_next_agent": {
      "type": "string",
      "minLength": 1
    },
    "blocking_reason": {
      "type": "string"
    }
  }
}
