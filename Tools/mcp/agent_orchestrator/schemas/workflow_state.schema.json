{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "agent_orchestrator/workflow_state.schema.json",
  "title": "WorkflowState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "input_task",
    "mode",
    "module",
    "status",
    "pipeline",
    "current_step_index",
    "step_results",
    "required_mcps"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "input_task": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": [
        "implement-change",
        "review-change",
        "spec-driven"
      ]
    },
    "module": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "received",
        "planned",
        "running",
        "blocked",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "pipeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "agent",
          "status",
          "can_run_in_parallel"
        ],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "agent": {
            "type": "string",
            "enum": [
              "Coordinator",
              "Code Writer Agent",
              "Test Writer Agent",
              "Spec Conformance Agent",
              "Code Review Agent",
              "Coverage & Gaps Agent"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "running",
              "completed",
              "blocked",
              "failed",
              "skipped"
            ]
          },
          "can_run_in_parallel": {
            "type": "boolean"
          },
          "blocking_dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          }
        }
      }
    },
    "current_step_index": {
      "type": "integer",
      "minimum": 0
    },
    "step_results": {
      "type": "array",
      "items": {
        "$ref": "agent_result.schema.json"
      }
    },
    "required_mcps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changed_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "changed_test_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "final_report": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string"
        },
        "completion_reason": {
          "type": "string"
        },
        "remaining_followups": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      }
    }
  }
}
