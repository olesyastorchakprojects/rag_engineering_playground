{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Execution/rag_runtime/schemas/request_capture.schema.json",
  "title": "Request Capture",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "RetrievalQualityMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evaluated_k",
        "recall_soft",
        "recall_strict",
        "rr_soft",
        "rr_strict",
        "ndcg",
        "num_relevant_soft",
        "num_relevant_strict"
      ],
      "properties": {
        "evaluated_k": {
          "type": "integer",
          "minimum": 1
        },
        "recall_soft": {
          "type": "number"
        },
        "recall_strict": {
          "type": "number"
        },
        "rr_soft": {
          "type": "number"
        },
        "rr_strict": {
          "type": "number"
        },
        "ndcg": {
          "type": "number"
        },
        "first_relevant_rank_soft": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "first_relevant_rank_strict": {
          "oneOf": [
            { "type": "null" },
            { "type": "integer", "minimum": 1 }
          ]
        },
        "num_relevant_soft": {
          "type": "integer",
          "minimum": 0
        },
        "num_relevant_strict": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "required": [
    "runtime_run_id",
    "request_id",
    "trace_id",
    "received_at",
    "raw_query",
    "normalized_query",
    "input_token_count",
    "pipeline_config_version",
    "corpus_version",
    "retriever_version",
    "retriever_kind",
    "retriever_config",
    "embedding_model",
    "prompt_template_id",
    "prompt_template_version",
    "generation_model",
    "generation_config",
    "reranker_kind",
    "reranker_config",
    "top_k_requested",
    "retrieval_results",
    "final_answer",
    "prompt_tokens",
    "completion_tokens",
    "total_tokens"
  ],
  "properties": {
    "runtime_run_id": {
      "type": "string",
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "raw_query": {
      "type": "string",
      "minLength": 1
    },
    "normalized_query": {
      "type": "string",
      "minLength": 1
    },
    "input_token_count": {
      "type": "integer",
      "minimum": 1
    },
    "pipeline_config_version": {
      "type": "string",
      "minLength": 1
    },
    "corpus_version": {
      "type": "string",
      "minLength": 1
    },
    "retriever_version": {
      "type": "string",
      "minLength": 1
    },
    "retriever_kind": {
      "type": "string",
      "enum": ["Dense", "Hybrid"]
    },
    "retriever_config": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "embedding_model_name",
            "embedding_endpoint",
            "embedding_dimension",
            "qdrant_collection_name",
            "qdrant_vector_name",
            "score_threshold",
            "corpus_version",
            "chunking_strategy"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "Dense"
            },
            "embedding_model_name": {
              "type": "string",
              "minLength": 1
            },
            "embedding_endpoint": {
              "type": "string",
              "minLength": 1
            },
            "embedding_dimension": {
              "type": "integer",
              "minimum": 1
            },
            "qdrant_collection_name": {
              "type": "string",
              "minLength": 1
            },
            "qdrant_vector_name": {
              "type": "string",
              "minLength": 1
            },
            "score_threshold": {
              "type": "number"
            },
            "corpus_version": {
              "type": "string",
              "minLength": 1
            },
            "chunking_strategy": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "embedding_model_name",
            "embedding_endpoint",
            "embedding_dimension",
            "qdrant_collection_name",
            "dense_vector_name",
            "sparse_vector_name",
            "score_threshold",
            "corpus_version",
            "chunking_strategy",
            "tokenizer_library",
            "tokenizer_source",
            "tokenizer_revision",
            "preprocessing_kind",
            "lowercase",
            "min_token_length",
            "vocabulary_path",
            "strategy"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "const": "Hybrid"
            },
            "embedding_model_name": {
              "type": "string",
              "minLength": 1
            },
            "embedding_endpoint": {
              "type": "string",
              "minLength": 1
            },
            "embedding_dimension": {
              "type": "integer",
              "minimum": 1
            },
            "qdrant_collection_name": {
              "type": "string",
              "minLength": 1
            },
            "dense_vector_name": {
              "type": "string",
              "minLength": 1
            },
            "sparse_vector_name": {
              "type": "string",
              "minLength": 1
            },
            "score_threshold": {
              "type": "number"
            },
            "corpus_version": {
              "type": "string",
              "minLength": 1
            },
            "chunking_strategy": {
              "type": "string",
              "minLength": 1
            },
            "tokenizer_library": {
              "type": "string",
              "minLength": 1
            },
            "tokenizer_source": {
              "type": "string",
              "minLength": 1
            },
            "tokenizer_revision": {
              "type": ["string", "null"]
            },
            "preprocessing_kind": {
              "type": "string",
              "minLength": 1
            },
            "lowercase": {
              "type": "boolean"
            },
            "min_token_length": {
              "type": "integer",
              "minimum": 0
            },
            "vocabulary_path": {
              "type": "string",
              "minLength": 1
            },
            "strategy": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["kind", "version", "query_weighting"],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "bag_of_words"
                    },
                    "version": {
                      "type": "string",
                      "minLength": 1
                    },
                    "query_weighting": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "kind",
                    "version",
                    "query_weighting",
                    "k1",
                    "b",
                    "idf_smoothing",
                    "term_stats_path"
                  ],
                  "properties": {
                    "kind": {
                      "type": "string",
                      "const": "bm25_like"
                    },
                    "version": {
                      "type": "string",
                      "minLength": 1
                    },
                    "query_weighting": {
                      "type": "string",
                      "minLength": 1
                    },
                    "k1": {
                      "type": "number"
                    },
                    "b": {
                      "type": "number"
                    },
                    "idf_smoothing": {
                      "type": "string",
                      "minLength": 1
                    },
                    "term_stats_path": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              ]
            }
          }
        }
      ]
    },
    "embedding_model": {
      "type": "string",
      "minLength": 1
    },
    "prompt_template_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt_template_version": {
      "type": "string",
      "minLength": 1
    },
    "generation_model": {
      "type": "string",
      "minLength": 1
    },
    "generation_config": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "model_endpoint", "temperature", "max_context_chunks", "input_cost_per_million_tokens", "output_cost_per_million_tokens"],
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "model_endpoint": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0
        },
        "max_context_chunks": {
          "type": "integer",
          "minimum": 1
        },
        "input_cost_per_million_tokens": {
          "type": "number",
          "minimum": 0
        },
        "output_cost_per_million_tokens": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "reranker_kind": {
      "type": "string",
      "enum": ["PassThrough", "Heuristic", "CrossEncoder"]
    },
    "reranker_config": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "final_k", "weights"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "Heuristic"
            },
            "final_k": {
              "type": "integer",
              "minimum": 1
            },
            "weights": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "retrieval_score",
                "query_term_coverage",
                "phrase_match_bonus",
                "title_section_match_bonus"
              ],
              "properties": {
                "retrieval_score": {
                  "type": "number",
                  "minimum": 0
                },
                "query_term_coverage": {
                  "type": "number",
                  "minimum": 0
                },
                "phrase_match_bonus": {
                  "type": "number",
                  "minimum": 0
                },
                "title_section_match_bonus": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "final_k", "cross_encoder"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "CrossEncoder"
            },
            "final_k": {
              "type": "integer",
              "minimum": 1
            },
            "cross_encoder": {
              "type": "object",
              "additionalProperties": false,
              "required": ["model_name", "url", "cost_per_million_tokens"],
              "properties": {
                "model_name": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "minLength": 1
                },
                "total_tokens": {
                  "type": ["integer", "null"],
                  "minimum": 0
                },
                "cost_per_million_tokens": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      ]
    },
    "top_k_requested": {
      "type": "integer",
      "minimum": 1
    },
    "retrieval_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "chunk_id",
          "document_id",
          "locator",
          "retrieval_score",
          "rerank_score",
          "selected_for_generation"
        ],
        "properties": {
          "chunk_id": {
            "type": "string",
            "minLength": 1
          },
          "document_id": {
            "type": "string",
            "minLength": 1
          },
          "locator": {
            "type": "string",
            "minLength": 1
          },
          "retrieval_score": {
            "type": "number"
          },
          "rerank_score": {
            "type": "number"
          },
          "selected_for_generation": {
            "type": "boolean"
          }
        }
      },
      "contains": {
        "type": "object",
        "properties": {
          "selected_for_generation": {
            "const": true
          }
        },
        "required": ["selected_for_generation"]
      }
    },
    "final_answer": {
      "type": "string",
      "minLength": 1
    },
    "prompt_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "completion_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "retrieval_stage_metrics": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/RetrievalQualityMetrics" }
      ]
    },
    "reranking_stage_metrics": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/RetrievalQualityMetrics" }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "retriever_kind": {
            "const": "Dense"
          }
        },
        "required": ["retriever_kind"]
      },
      "then": {
        "properties": {
          "retriever_config": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "embedding_model_name",
              "embedding_endpoint",
              "embedding_dimension",
              "qdrant_collection_name",
              "qdrant_vector_name",
              "score_threshold",
              "corpus_version",
              "chunking_strategy"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "Dense"
              },
              "embedding_model_name": {
                "type": "string",
                "minLength": 1
              },
              "embedding_endpoint": {
                "type": "string",
                "minLength": 1
              },
              "embedding_dimension": {
                "type": "integer",
                "minimum": 1
              },
              "qdrant_collection_name": {
                "type": "string",
                "minLength": 1
              },
              "qdrant_vector_name": {
                "type": "string",
                "minLength": 1
              },
              "score_threshold": {
                "type": "number"
              },
              "corpus_version": {
                "type": "string",
                "minLength": 1
              },
              "chunking_strategy": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retriever_kind": {
            "const": "Hybrid"
          }
        },
        "required": ["retriever_kind"]
      },
      "then": {
        "properties": {
          "retriever_config": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "embedding_model_name",
              "embedding_endpoint",
              "embedding_dimension",
              "qdrant_collection_name",
              "dense_vector_name",
              "sparse_vector_name",
              "score_threshold",
              "corpus_version",
              "chunking_strategy",
              "tokenizer_library",
              "tokenizer_source",
              "tokenizer_revision",
              "preprocessing_kind",
              "lowercase",
              "min_token_length",
              "vocabulary_path",
              "strategy"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "const": "Hybrid"
              },
              "embedding_model_name": {
                "type": "string",
                "minLength": 1
              },
              "embedding_endpoint": {
                "type": "string",
                "minLength": 1
              },
              "embedding_dimension": {
                "type": "integer",
                "minimum": 1
              },
              "qdrant_collection_name": {
                "type": "string",
                "minLength": 1
              },
              "dense_vector_name": {
                "type": "string",
                "minLength": 1
              },
              "sparse_vector_name": {
                "type": "string",
                "minLength": 1
              },
              "score_threshold": {
                "type": "number"
              },
              "corpus_version": {
                "type": "string",
                "minLength": 1
              },
              "chunking_strategy": {
                "type": "string",
                "minLength": 1
              },
              "tokenizer_library": {
                "type": "string",
                "minLength": 1
              },
              "tokenizer_source": {
                "type": "string",
                "minLength": 1
              },
              "tokenizer_revision": {
                "type": ["string", "null"]
              },
              "preprocessing_kind": {
                "type": "string",
                "minLength": 1
              },
              "lowercase": {
                "type": "boolean"
              },
              "min_token_length": {
                "type": "integer",
                "minimum": 0
              },
              "vocabulary_path": {
                "type": "string",
                "minLength": 1
              },
              "strategy": {
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["kind", "version", "query_weighting"],
                    "properties": {
                      "kind": {
                        "type": "string",
                        "const": "bag_of_words"
                      },
                      "version": {
                        "type": "string",
                        "minLength": 1
                      },
                      "query_weighting": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "kind",
                      "version",
                      "query_weighting",
                      "k1",
                      "b",
                      "idf_smoothing",
                      "term_stats_path"
                    ],
                    "properties": {
                      "kind": {
                        "type": "string",
                        "const": "bm25_like"
                      },
                      "version": {
                        "type": "string",
                        "minLength": 1
                      },
                      "query_weighting": {
                        "type": "string",
                        "minLength": 1
                      },
                      "k1": {
                        "type": "number"
                      },
                      "b": {
                        "type": "number"
                      },
                      "idf_smoothing": {
                        "type": "string",
                        "minLength": 1
                      },
                      "term_stats_path": {
                        "type": "string",
                        "minLength": 1
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reranker_kind": {
            "const": "PassThrough"
          }
        },
        "required": ["reranker_kind"]
      },
      "then": {
        "properties": {
          "reranker_config": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reranker_kind": {
            "const": "Heuristic"
          }
        },
        "required": ["reranker_kind"]
      },
      "then": {
        "properties": {
          "reranker_config": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "final_k", "weights"],
            "properties": {
              "kind": {
                "type": "string",
                "const": "Heuristic"
              },
              "final_k": {
                "type": "integer",
                "minimum": 1
              },
              "weights": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "retrieval_score",
                  "query_term_coverage",
                  "phrase_match_bonus",
                  "title_section_match_bonus"
                ],
                "properties": {
                  "retrieval_score": {
                    "type": "number",
                    "minimum": 0
                  },
                  "query_term_coverage": {
                    "type": "number",
                    "minimum": 0
                  },
                  "phrase_match_bonus": {
                    "type": "number",
                    "minimum": 0
                  },
                  "title_section_match_bonus": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reranker_kind": {
            "const": "CrossEncoder"
          }
        },
        "required": ["reranker_kind"]
      },
      "then": {
        "properties": {
          "reranker_config": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "final_k", "cross_encoder"],
            "properties": {
              "kind": {
                "type": "string",
                "const": "CrossEncoder"
              },
              "final_k": {
                "type": "integer",
                "minimum": 1
              },
              "cross_encoder": {
                "type": "object",
                "additionalProperties": false,
                "required": ["model_name", "url", "cost_per_million_tokens"],
                "properties": {
                  "model_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "url": {
                    "type": "string",
                    "minLength": 1
                  },
                  "total_tokens": {
                    "type": ["integer", "null"],
                    "minimum": 0
                  },
                  "cost_per_million_tokens": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
