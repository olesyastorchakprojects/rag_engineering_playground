    "line": [
      {
        "name": "running_header_chapter_prefixes",
        "type": "line_regex",
        "enabled": true,
        "scope": { "band": "top" },
        "pattern": "^\\s*chapter\\s+\\d+\\.\\s+.+?\\s+\\d+\\s*$",
        "flags": "i"
      },
      {
        "name": "book_title_header_anywhere",
        "type": "line_regex",
        "enabled": true,
        "scope": { "band": "any" },
        "pattern": "^\\s*understanding\\s+distributed\\s+systems(?:\\s+by\\s+.+)?\\s*$",
        "flags": "i"
      },
      {
        "name": "footer_page_number",
        "type": "line_regex",
        "enabled": true,
        "scope": { "band": "bottom" },
        "pattern": "^\\d+$",
        "flags": ""
      }
    ],
    "block": [
      {
        "name": "figure_captions_anywhere",
        "type": "region_rule",
        "enabled": true,
        "stage": "pre_line_rules",
        "target": "words",
        "references": [
          { "name": "median_gap", "kind": "median_gap", "fallback": 11.0 }
        ],
        "anchor": {
          "kind": "text_line_regex",
          "where": { "pattern": "^Figure\\s+(\\d{1,2})\\.(\\d{1,2})\\s*:\\s+", "flags": "" },
          "select": "all"
        },
        "candidate_region": {
          "kind": "lines_from_anchor_following_until",
          "max_lines": 4,
          "stop_when_any": [
            { "kind": "next_line_gap_gte_ratio", "reference": "median_gap", "value": 1.8 }
          ]
        },
        "action": { "type": "drop_region" }
      },
      {
        "name": "bottom_footnotes_after_separator_hrule",
        "type": "region_rule",
        "enabled": true,
        "stage": "post_line_rules",
        "target": "words",
        "references": [
          { "name": "body_median_font", "kind": "median_word_font_size_above_anchor", "fallback": 0.0 }
        ],
        "anchor": {
          "kind": "horizontal_line",
          "source": "page.lines",
          "where": {
            "top_gte_pct": 0.72,
            "x0_lte": 90.0,
            "width_gte": 100.0,
            "width_lte": 180.0,
            "linewidth_lte": 1.0
          },
          "select": "lowest"
        },
        "candidate_region": {
          "kind": "region_below_anchor_to_page_bottom",
          "offset": 2.0
        },
        "when": {
          "all": [
            {
              "kind": "all_words_below_anchor_size_ratio_lte",
              "reference": "body_median_font",
              "value": 0.82,
              "ignore_first_word_if_matches": "^\\d{1,2}$"
            }
          ]
        },
        "action": { "type": "drop_region" }
      }
    ],
    "text": [
      {
        "name": "remove_urls",
        "type": "regex_sub",
        "enabled": true,
        "pattern": "https?://|www\\.",
        "flags": "i",
        "repl": ""
      },
      {
        "name": "remove_inline_footnote_refs",
        "type": "regex_sub",
        "enabled": true,
        "pattern": "\\[\\d{1,3}(?:\\s*,\\s*\\d{1,3})*\\]",
        "flags": "",
        "repl": ""
      },
      {
        "name": "remove_inline_see_fig_ref",
        "type": "regex_sub",
        "enabled": true,
        "pattern": "\\(\\s*see\\s+(?:fig\\.?|figure)\\s+\\d{1,2}\\.\\d{1,2}\\s*\\)",
        "flags": "i",
        "repl": ""
      }
    ]
