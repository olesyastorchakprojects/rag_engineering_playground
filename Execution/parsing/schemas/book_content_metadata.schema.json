{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/book_content_metadata.schema.json",
  "title": "Book Content Metadata Schema",
  "description": "Schema for parsed book content metadata used by chunkers for section annotation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset",
    "source_pdf",
    "generated_from",
    "generated_on",
    "book",
    "page_numbering",
    "front_matter",
    "parts",
    "chapters",
    "sections",
    "subsections",
    "counts"
  ],
  "properties": {
    "dataset": {
      "type": "string",
      "minLength": 1
    },
    "source_pdf": {
      "type": "string",
      "minLength": 1
    },
    "generated_from": {
      "type": "string",
      "minLength": 1
    },
    "generated_on": {
      "type": "string",
      "minLength": 1
    },
    "book": {
      "$ref": "#/$defs/book"
    },
    "page_numbering": {
      "$ref": "#/$defs/page_numbering"
    },
    "front_matter": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/titled_range_entry"
      }
    },
    "parts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/part_entry"
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chapter_entry"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/section_entry"
      }
    },
    "subsections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/subsection_entry"
      }
    },
    "counts": {
      "$ref": "#/$defs/counts"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "positive_page": {
      "type": "integer",
      "minimum": 1
    },
    "page_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "$ref": "#/$defs/positive_page"
        },
        "end": {
          "$ref": "#/$defs/positive_page"
        }
      }
    },
    "ranges": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "book",
        "pdf"
      ],
      "properties": {
        "book": {
          "$ref": "#/$defs/page_span"
        },
        "pdf": {
          "$ref": "#/$defs/page_span"
        }
      }
    },
    "titled_range_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "ranges"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ranges": {
          "$ref": "#/$defs/ranges"
        }
      }
    },
    "part_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "part",
        "title",
        "ranges"
      ],
      "properties": {
        "part": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ranges": {
          "$ref": "#/$defs/ranges"
        }
      }
    },
    "chapter_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chapter",
        "title",
        "part",
        "ranges"
      ],
      "properties": {
        "chapter": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "part": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "ranges": {
          "$ref": "#/$defs/ranges"
        }
      }
    },
    "section_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section",
        "title",
        "chapter",
        "part",
        "ranges"
      ],
      "properties": {
        "section": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chapter": {
          "type": "integer",
          "minimum": 1
        },
        "part": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "ranges": {
          "$ref": "#/$defs/ranges"
        }
      }
    },
    "subsection_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subsection",
        "title",
        "section",
        "chapter",
        "part",
        "ranges"
      ],
      "properties": {
        "subsection": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "section": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chapter": {
          "type": "integer",
          "minimum": 1
        },
        "part": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "ranges": {
          "$ref": "#/$defs/ranges"
        }
      }
    },
    "book": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "edition",
        "version",
        "author",
        "date"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "edition": {
          "$ref": "#/$defs/non_empty_string"
        },
        "version": {
          "$ref": "#/$defs/non_empty_string"
        },
        "author": {
          "$ref": "#/$defs/non_empty_string"
        },
        "date": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "page_numbering": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "book_page_to_pdf_page_offset",
        "book_to_pdf_formula",
        "pdf_to_book_formula",
        "notes"
      ],
      "properties": {
        "book_page_to_pdf_page_offset": {
          "type": "integer"
        },
        "book_to_pdf_formula": {
          "$ref": "#/$defs/non_empty_string"
        },
        "pdf_to_book_formula": {
          "$ref": "#/$defs/non_empty_string"
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "front_matter",
        "parts",
        "chapters",
        "sections",
        "subsections"
      ],
      "properties": {
        "front_matter": {
          "type": "integer",
          "minimum": 0
        },
        "parts": {
          "type": "integer",
          "minimum": 0
        },
        "chapters": {
          "type": "integer",
          "minimum": 0
        },
        "sections": {
          "type": "integer",
          "minimum": 0
        },
        "subsections": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
