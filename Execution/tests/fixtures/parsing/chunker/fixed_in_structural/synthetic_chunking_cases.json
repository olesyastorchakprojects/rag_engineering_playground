[
  {
    "name": "split_per_sentence_and_preserve_parent_metadata",
    "config": {
      "chunking": {
        "target_tokens": 1,
        "overlap_ratio": 0.0,
        "chunking_version": "fixed_in_structural_test_v1"
      },
      "sentence_segmentation": {
        "library": "spacy",
        "library_version": "3.8.7",
        "language": "en"
      },
      "tokenizer": {
        "library": "tokenizers",
        "source": "Qwen/Qwen3-Embedding-0.6B"
      }
    },
    "chunks": [
      {
        "schema_version": 1,
        "doc_id": "doc-a",
        "chunk_id": "parent-a",
        "url": "local://doc-a",
        "document_title": "Doc A",
        "section_title": "Section A",
        "section_path": ["Part A", "Section A"],
        "chunk_index": 0,
        "page_start": 5,
        "page_end": 7,
        "tags": ["alpha"],
        "content_hash": "sha256:parent-a",
        "chunking_version": "structural_v1",
        "chunk_created_at": "2026-02-17T09:00:00Z",
        "text": "Alpha one. Alpha two."
      },
      {
        "schema_version": 1,
        "doc_id": "doc-b",
        "chunk_id": "parent-b",
        "url": "local://doc-b",
        "document_title": "Doc B",
        "section_title": "Section B",
        "section_path": ["Part B"],
        "chunk_index": 1,
        "page_start": 20,
        "page_end": 21,
        "tags": ["beta"],
        "content_hash": "sha256:parent-b",
        "chunking_version": "structural_v1",
        "chunk_created_at": "2026-02-17T09:01:00Z",
        "text": "Beta one. Beta two."
      }
    ],
    "expected_chunk_count": 4,
    "expected_doc_ids": ["doc-a", "doc-a", "doc-b", "doc-b"],
    "expected_page_ranges": [[5, 7], [5, 7], [20, 21], [20, 21]],
    "expected_section_paths": [
      ["Part A", "Section A"],
      ["Part A", "Section A"],
      ["Part B"],
      ["Part B"]
    ],
    "expected_text_contains": [
      "Alpha one.",
      "Alpha two.",
      "Beta one.",
      "Beta two."
    ],
    "forbid_cross_parent_text_pairs": [
      {
        "left_anchor": "Alpha two.",
        "right_anchor": "Beta one."
      }
    ]
  },
