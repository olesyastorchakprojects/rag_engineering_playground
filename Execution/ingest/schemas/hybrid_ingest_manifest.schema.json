{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "Execution/ingest/schemas/hybrid_ingest_manifest.schema.json",
  "title": "Hybrid Ingest Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "status",
    "started_at",
    "pipeline",
    "embedding",
    "sparse",
    "qdrant",
    "artifacts",
    "counts"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": ["running", "completed", "failed"]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ingest_config_version", "corpus_version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ingest_config_version": { "type": "string", "minLength": 1 },
        "corpus_version": { "type": "string", "minLength": 1 }
      }
    },
    "embedding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_name", "dimension"],
      "properties": {
        "model_name": { "type": "string", "minLength": 1 },
        "dimension": { "type": "integer", "minimum": 1 }
      }
    },
    "sparse": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy_kind",
        "strategy_version",
        "tokenizer_library",
        "tokenizer_source",
        "preprocessing_kind",
        "lowercase",
        "min_token_length",
        "vocabulary_name",
        "vocabulary_created_in_this_run",
        "out_of_vocabulary_token_count"
      ],
      "properties": {
        "strategy_kind": {
          "type": "string",
          "enum": ["bag_of_words", "bm25_like"]
        },
        "strategy_version": { "type": "string", "enum": ["v1"] },
        "tokenizer_library": { "type": "string", "enum": ["tokenizers"] },
        "tokenizer_source": { "type": "string", "minLength": 1 },
        "tokenizer_revision": { "type": "string", "minLength": 1 },
        "preprocessing_kind": { "type": "string", "enum": ["basic_word_v1"] },
        "lowercase": { "type": "boolean" },
        "min_token_length": { "type": "integer", "minimum": 1 },
        "vocabulary_name": { "type": "string", "minLength": 1 },
        "vocabulary_created_in_this_run": { "type": "boolean" },
        "out_of_vocabulary_token_count": { "type": "integer", "minimum": 0 }
      }
    },
    "qdrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_name",
        "dense_vector_name",
        "sparse_vector_name",
        "distance"
      ],
      "properties": {
        "collection_name": { "type": "string", "minLength": 1 },
        "dense_vector_name": { "type": "string", "minLength": 1 },
        "sparse_vector_name": { "type": "string", "minLength": 1 },
        "distance": {
          "type": "string",
          "enum": ["Cosine", "Dot", "Euclid", "Manhattan"]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vocabulary_path", "manifest_path"],
      "properties": {
        "vocabulary_path": { "type": "string", "minLength": 1 },
        "manifest_path": { "type": "string", "minLength": 1 }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chunks_total",
        "chunks_processed",
        "chunks_failed",
        "chunks_skipped"
      ],
      "properties": {
        "chunks_total": { "type": "integer", "minimum": 0 },
        "chunks_processed": { "type": "integer", "minimum": 0 },
        "chunks_failed": { "type": "integer", "minimum": 0 },
        "chunks_skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "last_error": {
      "type": "string",
      "minLength": 1
    }
  }
}
