{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "config_contract/dense_ingest/dense_ingest_config_schema.json",
  "title": "Dense Ingest Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pipeline",
    "embedding",
    "qdrant",
    "idempotency",
    "logging"
  ],
  "properties": {
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "chunk_schema_version",
        "ingest_config_version",
        "corpus_version",
        "chunking_strategy"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "chunk_schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "ingest_config_version": {
          "type": "string",
          "minLength": 1
        },
        "corpus_version": {
          "type": "string",
          "pattern": "^v[1-9][0-9]*$"
        },
        "chunking_strategy": {
          "type": "string",
          "enum": ["structural", "fixed"]
        }
      }
    },
    "embedding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "input",
        "transport",
        "retry"
      ],
      "properties": {
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "dimension"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "dimension": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "text_source"
          ],
          "properties": {
            "text_source": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "transport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "timeout_sec",
            "max_batch_size"
          ],
          "properties": {
            "timeout_sec": {
              "type": "integer",
              "minimum": 1
            },
            "max_batch_size": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_attempts",
            "backoff"
          ],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "backoff": {
              "type": "string",
              "enum": [
                "exponential"
              ]
            }
          }
        }
      }
    },
    "qdrant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection",
        "point_id",
        "transport",
        "retry"
      ],
      "properties": {
        "collection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "distance",
            "vector_name",
            "create_if_missing"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "distance": {
              "type": "string",
              "enum": [
                "Cosine",
                "Dot",
                "Euclid",
                "Manhattan"
              ]
            },
            "vector_name": {
              "type": "string",
              "enum": [
                "default"
              ]
            },
            "create_if_missing": {
              "type": "boolean"
            }
          }
        },
        "point_id": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strategy",
            "namespace_uuid",
            "format"
          ],
          "properties": {
            "strategy": {
              "type": "string",
              "enum": [
                "uuid5(chunk.chunk_id)"
              ]
            },
            "namespace_uuid": {
              "type": "string",
              "format": "uuid"
            },
            "format": {
              "type": "string",
              "enum": [
                "canonical_uuid"
              ]
            }
          }
        },
        "transport": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "timeout_sec",
            "upsert_batch_size"
          ],
          "properties": {
            "timeout_sec": {
              "type": "integer",
              "minimum": 1
            },
            "upsert_batch_size": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "retry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_attempts",
            "backoff"
          ],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "backoff": {
              "type": "string",
              "enum": [
                "exponential"
              ]
            }
          }
        }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "fingerprint_fields",
        "on_fingerprint_change",
        "on_metadata_change"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "field_tuple_hash"
          ]
        },
        "fingerprint_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "on_fingerprint_change": {
          "type": "string",
          "enum": [
            "log_and_skip"
          ]
        },
        "on_metadata_change": {
          "type": "string",
          "enum": [
            "update_changed_fields"
          ]
        }
      }
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failed_chunk_log_path",
        "skipped_chunk_log_path"
      ],
      "properties": {
        "failed_chunk_log_path": {
          "type": "string",
          "minLength": 1
        },
        "skipped_chunk_log_path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
