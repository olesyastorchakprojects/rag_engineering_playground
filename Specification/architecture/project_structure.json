{
  "document": {
    "name": "project_structure",
    "purpose": "Machine-readable repository layout for code-generating models and coding agents.",
    "human_companion": "Specification/architecture/project_structure.md",
    "rules": [
      "Prefer this structure over inventing new locations.",
      "Use OldStructure only as legacy reference.",
      "Keep .env in repository root.",
      "Use Specification/architecture/module_variant_policy.md to distinguish implementation variants, shared logic, and runtime profiles."
    ]
  },
  "top_level": {
    "Execution": {
      "purpose": "Runnable system code, executable tests, runtime configs, runtime schemas, and thin entrypoints.",
      "allowed_contents": [
        "production code",
        "executable tests",
        "runtime configs",
        "runtime schemas",
        "book-specific runtime resources",
        "thin entrypoints"
      ]
    },
    "Specification": {
      "purpose": "The specifications used to guide code generation, test generation, architecture decisions, and repository organization.",
      "allowed_contents": [
        "codegen prompts",
        "testgen prompts",
        "high-level task prompts",
        "human-readable contracts",
        "architecture docs",
        "test matrices"
      ]
    },
    "Measurement": {
      "purpose": "Rules and tooling for measuring quality, latency, cost, robustness, and usefulness.",
      "allowed_contents": [
        "evaluation harnesses",
        "benchmark definitions",
        "scoring logic",
        "dashboard configs",
        "comparison tooling"
      ]
    },
    "Evidence": {
      "purpose": "Artifacts produced by concrete runs, evaluations, and experiments.",
      "allowed_contents": [
        "pages.jsonl",
        "chunks.jsonl",
        "ingest manifests",
        "failed chunk logs",
        "run metadata",
        "benchmark outputs",
        "retrieval outputs",
        "answer outputs",
        "generated reports",
        "metric snapshots",
        "experiment result tables"
      ]
    },
    "AgentContext": {
      "purpose": "Agent-operating rules and repository conventions.",
      "allowed_contents": [
        "AGENTS.md",
        "agent workflow rules",
        "repo conventions",
        "tooling rules",
        "review checklists"
      ],
      "related_architecture": [
        "Specification/architecture/agent_workflow_policy.md"
      ]
    },
    "Documentation": {
      "purpose": "Human-oriented documentation and writeups.",
      "allowed_contents": [
        "README-like material",
        "narrative docs",
        "project writeups",
        "explanatory documentation"
      ]
    },
    "OldStructure": {
      "purpose": "Archived legacy repository layout kept only for reference during migration.",
      "rules": [
        "Do not place new files here.",
        "Use only as historical reference."
      ]
    }
  },
